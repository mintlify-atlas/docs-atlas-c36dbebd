  "keyFeatures": [
    "Full blockchain validation and consensus enforcement",
    "P2P network protocol implementation with support for Tor, I2P, and CJDNS",
    "Hierarchical Deterministic (HD) wallet with descriptor support",
    "Comprehensive JSON-RPC and REST APIs",
    "Mining and block template generation",
    "Partially Signed Bitcoin Transactions (PSBT) support",
    "Transaction mempool management and fee estimation",
    "ZMQ notifications for real-time event streaming",
    "Segregated Witness (SegWit) and Taproot support",
    "Multi-signature and time-locked transactions"
  ],
  "publicApiSurface": [
    "bitcoind - Full node daemon with RPC server",
    "bitcoin-qt - GUI application",
    "bitcoin-cli - Command-line RPC client",
    "bitcoin-tx - Transaction creation/manipulation utility",
    "bitcoin-wallet - Wallet management utility",
    "bitcoin-util - General utility commands",
    "JSON-RPC endpoints: getblockchaininfo, getblock, getrawtransaction, sendrawtransaction, getbalance, sendtoaddress, listunspent, etc.",
    "REST endpoints: /rest/block, /rest/tx, /rest/chaininfo, /rest/mempool",
    "ZMQ topics: zmqpubhashtx, zmqpubhashblock, zmqpubrawblock, zmqpubrawtx"
  ]
}
